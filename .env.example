# Required
ANTHROPIC_API_KEY=sk-ant-...

# Todoist API tokens — one per person
# Get from: Todoist → Settings → Integrations → Developer
TODOIST_TOKEN_1=
TODOIST_TOKEN_2=

# Optional
# HA_TOKEN=                    # Home Assistant long-lived access token
# ACTUAL_BUDGET_PASSWORD=      # Actual Budget server password

# Docker printing (headless_docker / headed_docker)
# PRINT_BRIEF=true             # "false" = generate PDF/UI only, don't print
# CUPS_SERVER=host:631         # CUPS server with the printer (container has none)
